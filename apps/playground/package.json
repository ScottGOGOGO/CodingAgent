{
  "name": "@vide/playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm --workspace @vide/contracts run build && tsc -b && vite build",
    "dev": "npm --workspace @vide/contracts run build && vite",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "typecheck": "npm --workspace @vide/contracts run build && tsc -b --pretty false"
  },
  "dependencies": {
    "@vide/contracts": "0.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
