AGENT_SERVICE_URL=http://127.0.0.1:8001
AGENT_SERVICE_TIMEOUT_MS=420000
# Set AGENT_SERVICE_TIMEOUT_MS=0 to disable the orchestrator-side request timeout
# and the local Undici headers/body timeout window entirely.
ORCHESTRATOR_PORT=4000
PLAYGROUND_PORT=5173
VITE_API_BASE=http://127.0.0.1:4000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/vide_agent
PROJECTS_ROOT=./data/projects
RUNNER_STRATEGY=auto
MODEL_PROVIDER=openai_compatible
MODEL_API_KEY=
MODEL_BASE_URL=
MODEL_NAME=
CLARIFIER_MODEL=
PLANNER_MODEL=
CODER_MODEL=
CRITIC_MODEL=
MODEL_WIRE_API=
MODEL_REASONING_EFFORT=
MODEL_VERBOSITY=
MODEL_DISABLE_RESPONSE_STORAGE=false
MODEL_TIMEOUT_SECONDS=90
# Set MODEL_TIMEOUT_SECONDS=0 only if you want the agent runtime to wait
# indefinitely for each model stage.

# Optional provider-specific blocks. If MODEL_* is empty, the runtime uses the
# block selected by MODEL_PROVIDER, or auto-picks the first complete block when
# MODEL_PROVIDER=openai_compatible.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3-coder-plus
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
# For GPT-5.x on Responses-compatible endpoints, recommended starting values:
# MODEL_WIRE_API=responses
# MODEL_REASONING_EFFORT=low
# MODEL_VERBOSITY=low
# MODEL_DISABLE_RESPONSE_STORAGE=true

GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL=

CLAUDE_API_KEY=
CLAUDE_BASE_URL=
CLAUDE_MODEL=
